.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 56rpx;
  color: #5d4037;
  background-color: #fff9fa;
  background-image:
    radial-gradient(#ffe5ec 14%, transparent 16%),
    radial-gradient(#ffe5ec 14%, transparent 16%);
  background-size: 40rpx 40rpx;
  background-position: 0 0, 20rpx 20rpx;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.brand-mark {
  width: 70rpx;
  height: 70rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  color: #ffffff;
  text-align: center;
  font-size: 32rpx;
  line-height: 70rpx;
  background: transparent;
  box-shadow: 0 8rpx 20rpx rgba(255, 112, 144, 0.25);
  margin-right: 18rpx;
}

.title {
  color: #5d4037;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.subtitle {
  margin-top: 6rpx;
  color: #8d6e63;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
}

.panel {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 2rpx solid #ffe5ec;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(255, 143, 171, 0.1);
}

.panel-title {
  margin-bottom: 18rpx;
  color: #5d4037;
  font-size: 30rpx;
  font-weight: 900;
}

.field {
  margin-bottom: 18rpx;
}

.field.last {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #8d6e63;
  font-size: 24rpx;
  font-weight: 900;
}

.input,
.picker {
  box-sizing: border-box;
  width: 100%;
  border: 2rpx solid #ffe5ec;
  border-radius: 18rpx;
  color: #5d4037;
  font-size: 27rpx;
  font-weight: 800;
  background: #ffffff;
}

.input,
.picker {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

button::after {
  border: 0;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.label-row .label {
  margin-bottom: 0;
}

.model-tools {
  display: flex;
  align-items: center;
}

.model-toggle,
.model-refresh {
  margin-left: 12rpx;
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
  color: #8d6e63;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.5;
  background: #fff1f4;
}

.model-refresh.loading {
  color: #ffffff;
  background: #ffc2d1;
}

.model-picker {
  margin-top: 12rpx;
}

.model-picker-view {
  color: #8d6e63;
  font-weight: 700;
}

.save-btn {
  height: 88rpx;
  margin: 8rpx 0 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
  background: #ff9eb5;
  box-shadow: 0 10rpx 24rpx rgba(255, 112, 144, 0.26);
}

.save-btn.dirty {
  background: #ff7a90;
}
