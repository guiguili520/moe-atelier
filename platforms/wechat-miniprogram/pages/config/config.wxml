<view class="page">
  <view class="header">
    <image class="brand-mark" src="/assets/logo.png" mode="aspectFill"></image>
    <view>
      <view class="title">生成配置</view>
      <view class="subtitle">填好地址和 Key 会自动拉取模型，改完记得点底部保存。</view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">接口</view>
    <view class="field">
      <text class="label">接口格式</text>
      <picker mode="selector" range="{{formatOptions}}" range-key="label" value="{{formatIndex}}" bindchange="handleFormatChange">
        <view class="picker">{{formatOptions[formatIndex].label}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="label">API 地址</text>
      <input class="input" value="{{config.apiUrl}}" placeholder="https://api.openai.com/v1" bindinput="handleApiUrlInput" />
    </view>
    <view class="field">
      <text class="label">API Key</text>
      <input class="input" password value="{{config.apiKey}}" placeholder="填入你的 Key" bindinput="handleApiKeyInput" />
    </view>
    <view class="field last">
      <view class="label-row">
        <text class="label">模型</text>
        <view class="model-tools">
          <view class="model-toggle" catchtap="toggleShowAll">{{showAllModels ? '只看生图' : '显示全部'}}</view>
          <view class="model-refresh {{loadingModels ? 'loading' : ''}}" catchtap="refreshModels">{{loadingModels ? '获取中' : '刷新'}}</view>
        </view>
      </view>
      <input class="input" value="{{config.model}}" placeholder="gpt-image-1 / 自定义输入" bindinput="handleModelInput" />
      <picker class="model-picker" mode="selector" range="{{models}}" bindchange="handleModelPick" disabled="{{models.length === 0}}">
        <view class="picker model-picker-view">{{models.length ? ('从 ' + models.length + ' 个可用模型选择') : '填好地址和 Key 后自动获取'}}</view>
      </picker>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">生成参数</view>
    <view class="field {{isOpenAI ? '' : 'last'}}">
      <text class="label">画幅</text>
      <picker mode="selector" range="{{sizeOptions}}" range-key="desc" value="{{sizeIndex}}" bindchange="handleSizeChange">
        <view class="picker">{{sizeOptions[sizeIndex].label}} · {{sizeOptions[sizeIndex].desc}}</view>
      </picker>
    </view>
    <block wx:if="{{isOpenAI}}">
      <view class="field">
        <text class="label">质量</text>
        <picker mode="selector" range="{{qualityOptions}}" range-key="desc" value="{{qualityIndex}}" bindchange="handleQualityChange">
          <view class="picker">{{qualityOptions[qualityIndex].label}} · {{qualityOptions[qualityIndex].desc}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">输出格式</text>
        <picker mode="selector" range="{{outputFormatOptions}}" range-key="desc" value="{{outputFormatIndex}}" bindchange="handleOutputFormatChange">
          <view class="picker">{{outputFormatOptions[outputFormatIndex].label}} · {{outputFormatOptions[outputFormatIndex].desc}}</view>
        </picker>
      </view>
      <view class="field last">
        <text class="label">背景</text>
        <picker mode="selector" range="{{backgroundOptions}}" range-key="desc" value="{{backgroundIndex}}" bindchange="handleBackgroundChange">
          <view class="picker">{{backgroundOptions[backgroundIndex].label}} · {{backgroundOptions[backgroundIndex].desc}}</view>
        </picker>
      </view>
    </block>
  </view>

  <button class="save-btn {{dirty ? 'dirty' : ''}}" bindtap="saveAll">{{dirty ? '保存配置（有改动）' : '保存配置'}}</button>
</view>
