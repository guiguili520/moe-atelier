page {
  min-height: 100%;
  color: #5d4037;
  background: #fff9fa;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

/* 统一原生按钮：去掉 v2 默认灰底/外边距与 ::after 边框，避免出现「双层按钮」。
   各按钮自身的背景色由更高优先级的 class 选择器保留。 */
button {
  margin: 0;
  padding: 0;
  font-weight: 700;
  background-color: transparent;
}

button::after {
  border: none;
}
